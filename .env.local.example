# Copia este archivo a .env.local y completa con los datos de tu proyecto Firebase.
# Si dejas estas variables vacías, la app arranca en MODO DEMO (datos simulados en vivo).
#
# Las claves NEXT_PUBLIC_* son visibles en el cliente: es normal en Firebase.
# La seguridad real la dan las REGLAS de la base (ver especificacion, sección 7), no ocultar la API key.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
