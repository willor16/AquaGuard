{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    "tanks": {
      "$tankId": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('tanks').child($tankId).val() === true",
        "meta": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "config": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() !== 'lectura' || root.child('users').child(auth.uid).child('role').val() === 'device')"
        },
        "desired": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() !== 'lectura' || root.child('users').child(auth.uid).child('role').val() === 'device')"
        },
        "reported": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'device'"
        },
        "alerts": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'device'"
        },
        "events": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'device'"
        },
        "history": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'device'"
        }
      }
    }
  }
}
